# Helpara AI
# Digital samhällsguide

import os
from flask import Flask, request, jsonify, render_template_string

app = Flask(__name__)

# Enkel AI-logik
def helpara_ai_response(question):

    q = question.lower()

    if "1177" in q or "vård" in q or "sjuk" in q:
        return "För medicinska frågor rekommenderas att kontakta 1177 eller din vårdcentral."

    elif "bygglov" in q:
        return "Information om bygglov finns på din kommuns webbplats under bygg och bo."

    elif "skola" in q:
        return "Kontakta kommunens utbildningsförvaltning för information om skolor och ansökan."

    elif "sophämtning" in q or "sopor" in q:
        return "Sophämtning hanteras av kommunens avfallsservice. Kontrollera din kommuns schema."

    elif "socialt stöd" in q:
        return "Du kan kontakta socialtjänsten i din kommun för information om stöd och hjälp."

    else:
        return "Helpara AI hjälper dig hitta rätt information om vård och kommunala tjänster."

