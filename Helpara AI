# API
@app.route("/ask", methods=["POST"])
def ask():

    data = request.json
    question = data.get("question","")

    answer = helpara_ai_response(question)

    return jsonify({"answer":answer})

# Starta server
if __name__ == "__main__":

    port = int(os.environ.get("PORT",5000))

    app.run(host="0.0.0.0", port=port)
